{
  "name": "agihackathon26dermbrief",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "node --check api/daily-brief.js && node --check api/process-evidence.js && node --check api/ai-evidence.js && node --check api/audit-integrity.js && node --check api/audit-manifest.js",
    "test": "node --test test/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.mjs",
    "test:e2e": "playwright test",
    "prebuild": "npm run test:journals && npm run test:inbox && npm run test:ai",
    "build": "tsc -b && vite build",
    "check": "tsc -b --pretty false",
    "test:journals": "node scripts/test-journals.mjs",
    "test:inbox": "node scripts/test-daily-brief.mjs",
    "test:ai": "node scripts/test-ai-governance.mjs",
    "preview": "vite preview",
    "validate": "npm run lint && npm test && npm run test:coverage && npm run check && npm run build"
  },
  "dependencies": {
    "@insforge/sdk": "1.4.5",
    "ai": "6.0.224",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
