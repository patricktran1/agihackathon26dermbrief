# Browser-side InsForge configuration. Add these to Vercel and redeploy.
VITE_INSFORGE_BASE_URL=https://your-project.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key

# The same InsForge project, used by the local Cotal bridge worker.
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_ANON_KEY=your-anon-key

# Evidence API used by the bridge worker.
DERMBRIEF_API_URL=https://agihackathon26dermbrief.vercel.app/api/process-evidence

# Optional NCBI key for higher PubMed request limits in the Vercel function.
NCBI_API_KEY=

# Cotal mesh. With no auth values, start a loopback demo mesh using `cotal up --open`.
COTAL_SERVER=nats://127.0.0.1:4222
COTAL_SPACE=dermbrief-evidenceops
COTAL_TOKEN=
COTAL_USER=
COTAL_PASS=

# Worker tuning.
WORKER_ID=patrick-demo-laptop
WORKER_POLL_MS=900
